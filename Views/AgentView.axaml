<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartToolbox.ViewModels"
             x:Class="SmartToolbox.Views.AgentView"
             x:DataType="vm:AgentViewModel">

    <Grid ColumnDefinitions="250,*">
        <Border Background="#2D2D2D" Padding="10">
            <StackPanel Spacing="10">
                <TextBlock Text="🤖 AI Agent" FontSize="18" FontWeight="Bold"/>
                
                <TextBlock Text="任务历史" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <ListBox ItemsSource="{Binding TaskHistory}" 
                         SelectedItem="{Binding SelectedTask}"
                         Height="200">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Description}" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{Binding State}" FontSize="12" Foreground="Gray"/>
                                    <TextBlock Text="{Binding Duration, StringFormat={}{0:F1}s}" FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="执行步骤" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <ListBox ItemsSource="{Binding CurrentSubTasks}" Height="150">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="✓" Foreground="Green" IsVisible="{Binding IsSuccessful}"/>
                                <TextBlock Text="✗" Foreground="Red" IsVisible="{Binding !IsSuccessful}"/>
                                <TextBlock Text="○" Foreground="Gray" IsVisible="{Binding !IsCompleted}"/>
                                <TextBlock Text="{Binding Description}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Content="清空历史" Command="{Binding ClearHistoryCommand}" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
            <Border Background="#2D2D2D" Padding="15" Margin="10,0,10,0">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="优先级:" VerticalAlignment="Center"/>
                        <DropDown SelectedItem="{Binding SelectedPriority}" Width="100">
                            <DropDown.Items>
                                <vm:TaskPriority>Low</vm:TaskPriority>
                                <vm:TaskPriority>Medium</vm:TaskPriority>
                                <vm:TaskPriority>High</vm:TaskPriority>
                                <vm:TaskPriority>Critical</vm:TaskPriority>
                            </DropDown.Items>
                        </DropDown>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Grid.Column="1">
                        <Button Content="执行任务" Command="{Binding CreateAndExecuteTaskCommand}" IsEnabled="{Binding !IsExecuting}"/>
                        <Button Content="反思" Command="{Binding ReflectOnTaskCommand}" IsEnabled="{Binding !IsExecuting}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="10" RowDefinitions="*,*">
                <Border Background="#2D2D2D" CornerRadius="8" Padding="10">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="任务描述" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding TaskInput}" 
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Watermark="描述你想要完成的任务..."/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#2D2D2D" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="执行结果" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding TaskResult}" 
                                 Grid.Row="1"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 Watermark="结果将显示在这里..."/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="#1E1E1E" Padding="10" Margin="10,0,10,10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <TextBlock Text="{Binding StatusMessage}"/>
                        <ProgressBar Value="{Binding Progress}" Maximum="100" Width="100" IsVisible="{Binding IsExecuting}"/>
                        <TextBlock Text="{Binding CurrentStep}" Foreground="Gray"/>
                    </StackPanel>
                    <Button Content="清空日志" Command="{Binding ClearLogCommand}" Grid.Column="1"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
