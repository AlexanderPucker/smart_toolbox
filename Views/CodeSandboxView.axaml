<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartToolbox.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SmartToolbox.Views.CodeSandboxView"
             x:DataType="vm:CodeSandboxViewModel">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Background="#2D2D2D" Padding="15">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="🏃 代码沙盒" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                    <DropDown ItemsSource="{Binding Languages}" 
                              SelectedItem="{Binding SelectedLanguage}"
                              VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" Grid.Column="1">
                    <Button Content="运行" Command="{Binding RunCodeCommand}" IsEnabled="{Binding !IsRunning}"/>
                    <Button Content="停止" Command="{Binding StopExecutionCommand}" IsEnabled="{Binding IsRunning}"/>
                    <Button Content="解释" Command="{Binding ExplainCodeCommand}"/>
                    <Button Content="修复" Command="{Binding FixCodeCommand}"/>
                    <Button Content="模板" Command="{Binding LoadTemplateCommand}"/>
                    <Button Content="清空" Command="{Binding ClearCodeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="10">
            <Border Background="#1E1E1E" CornerRadius="8" Padding="10">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="代码输入" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding CodeInput}" 
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas,Courier New,monospace"
                             FontSize="14"
                             Watermark="在此输入代码..."/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Padding="10" Margin="10,0,0,0">
                <Grid RowDefinitions="*,Auto">
                    <TextBox Text="{Binding OutputText}" 
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             FontFamily="Consolas,Courier New,monospace"
                             Watermark="输出将显示在这里..."/>
                    <TextBox Text="{Binding ErrorText}" 
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Foreground="#FF6B6B"
                             FontFamily="Consolas,Courier New,monospace"
                             Watermark="错误信息将显示在这里..."
                             Height="100"
                             Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#2D2D2D" Padding="10" Margin="10,0,10,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <TextBlock Text="{Binding StatusMessage}"/>
                    <TextBlock Text="{Binding ExecutionTime, StringFormat=耗时: {0:F2}s}" Foreground="Gray"/>
                    <TextBlock Text="{Binding ExitCode, StringFormat=退出码: {0}}" Foreground="Gray"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1">
                    <TextBlock Text="超时(秒):" VerticalAlignment="Center"/>
                    <NumericUpDown Value="{Binding TimeoutSeconds}" Minimum="1" Maximum="60" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
