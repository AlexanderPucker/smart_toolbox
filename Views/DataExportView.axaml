<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartToolbox.ViewModels"
             x:Class="SmartToolbox.Views.DataExportView"
             x:DataType="vm:DataExportViewModel">

    <Grid RowDefinitions="Auto,*">
        <Border Background="#2D2D2D" Padding="15">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="📤 数据导出" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="5" Grid.Column="1">
                    <Button Content="导出全部" Command="{Binding ExportAllCommand}"/>
                    <Button Content="打开目录" Command="{Binding OpenDirectoryCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="10">
            <Border Background="#2D2D2D" CornerRadius="8" Padding="15">
                <StackPanel Spacing="15">
                    <TextBlock Text="导出选项" FontWeight="SemiBold" FontSize="16"/>
                    
                    <TextBlock Text="导出格式"/>
                    <DropDown SelectedItem="{Binding SelectedFormat}" HorizontalAlignment="Stretch">
                        <DropDown.Items>
                            <x:String>JSON</x:String>
                            <x:String>Markdown</x:String>
                            <x:String>HTML</x:String>
                            <x:String>PlainText</x:String>
                        </DropDown.Items>
                    </DropDown>

                    <TextBlock Text="导出范围"/>
                    <DropDown SelectedItem="{Binding SelectedScope}" HorizontalAlignment="Stretch">
                        <DropDown.Items>
                            <x:String>当前对话</x:String>
                            <x:String>所有对话</x:String>
                        </DropDown.Items>
                    </DropDown>

                    <CheckBox Content="包含元数据" IsChecked="{Binding IncludeMetadata}"/>
                    <CheckBox Content="包含时间戳" IsChecked="{Binding IncludeTimestamps}"/>
                    <CheckBox Content="包含 Token 统计" IsChecked="{Binding IncludeTokenCounts}"/>
                    <CheckBox Content="包含费用信息" IsChecked="{Binding IncludeCosts}"/>
                    <CheckBox Content="包含系统提示词" IsChecked="{Binding IncludeSystemPrompts}"/>
                    <CheckBox Content="匿名化处理" IsChecked="{Binding Anonymize}"/>
                    <CheckBox Content="压缩输出" IsChecked="{Binding CompressOutput}"/>

                    <Button Content="开始导出" Command="{Binding ExportCommand}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="8" Padding="15" Margin="10,0,0,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="最近导出" FontWeight="SemiBold" FontSize="16"/>
                    <ListBox ItemsSource="{Binding RecentExports}" Grid.Row="1" Margin="0,10,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MM-dd HH:mm}}" 
                                               Foreground="Gray" 
                                               Grid.Column="1"
                                               Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
