<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartToolbox.ViewModels"
             xmlns:models="using:SmartToolbox.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
             x:Class="SmartToolbox.Views.FileMoverView"
             x:DataType="vm:FileMoverViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#005A9B"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#004578"/>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#DC3545"/>
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#C82333"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style Selector="Button.success:pointerover">
            <Setter Property="Background" Value="#218838"/>
        </Style>
        <Style Selector="Button.cancel">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>
        <Style Selector="Button.cancel:pointerover">
            <Setter Property="Background" Value="#5A6268"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TextBox.dragover">
            <Setter Property="BorderBrush" Value="#007ACC"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <!-- 顶部操作区 -->
        <StackPanel Grid.Row="0" Spacing="12">
            <!-- 源文件夹 -->
            <Grid ColumnDefinitions="100,*,Auto">
                <TextBlock Grid.Column="0" Text="源文件夹:" VerticalAlignment="Center" FontWeight="Medium" FontSize="15"/>
                <TextBox Grid.Column="1" Name="SourceFolderTextBox"
                         Watermark="选择或拖入源文件夹..."
                         IsReadOnly="True"
                         FontFamily="Consolas, monospace"
                         Text="{Binding SourceFolderPath}"
                         Margin="10,0,0,0"/>
                <Button Grid.Column="2" Margin="10,0,0,0"
                        Command="{Binding SelectSourceFolderCommand}">
                    <TextBlock Text="浏览"/>
                </Button>
            </Grid>

            <!-- 目标文件夹 -->
            <Grid ColumnDefinitions="100,*,Auto">
                <TextBlock Grid.Column="0" Text="目标文件夹:" VerticalAlignment="Center" FontWeight="Medium" FontSize="15"/>
                <TextBox Grid.Column="1" Name="TargetFolderTextBox"
                         Watermark="选择或拖入目标文件夹..."
                         IsReadOnly="True"
                         FontFamily="Consolas, monospace"
                         Text="{Binding TargetFolderPath}"
                         Margin="10,0,0,0"/>
                <Button Grid.Column="2" Margin="10,0,0,0"
                        Command="{Binding SelectTargetFolderCommand}">
                    <TextBlock Text="浏览"/>
                </Button>
            </Grid>

            <!-- 过滤器 + 大小写 + 子文件夹 + 按钮 -->
            <Grid ColumnDefinitions="Auto,180,Auto,140,Auto,Auto,Auto,*">
                <TextBlock Grid.Column="0" Text="文件类型:" VerticalAlignment="Center" FontSize="14"/>
                <ComboBox Grid.Column="1" Name="MoveFileFilterComboBox"
                          ItemsSource="{Binding FilterOptions}"
                          SelectedItem="{Binding SelectedFilter}"
                          HorizontalAlignment="Stretch"
                          Margin="10,0,0,0"/>
                <TextBlock Grid.Column="2" Text="文件名:" VerticalAlignment="Center" FontSize="14" Margin="15,0,0,0"/>
                <ComboBox Grid.Column="3" Name="CaseConversionComboBox"
                          ItemsSource="{Binding CaseConversionOptions}"
                          SelectedItem="{Binding SelectedCaseConversion}"
                          HorizontalAlignment="Stretch"
                          Margin="10,0,0,0"/>
                <CheckBox Grid.Column="4" Content="含子文件夹"
                          IsChecked="{Binding IncludeSubfolders}"
                          Margin="15,0,0,0" VerticalAlignment="Center"/>
                <Button Grid.Column="5" Name="PreviewButton" Margin="15,0,0,0"
                        Command="{Binding PreviewCommand}"
                        Classes.cancel="{Binding IsProcessing}">
                    <TextBlock Text="{Binding IsProcessing, Converter={StaticResource PreviewBtnTextConverter}}"/>
                </Button>
                <Button Grid.Column="6" Classes="success" Margin="10,0,0,0" MinWidth="100"
                        Command="{Binding ExecuteMoveCommand}">
                    <TextBlock Text="执行移动"/>
                </Button>
                <Button Grid.Column="7" Margin="10,0,0,0"
                        Command="{Binding ClearPreviewCommand}">
                    <TextBlock Text="清除"/>
                </Button>
            </Grid>

            <!-- 文件统计 -->
            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{Binding FileCount, StringFormat='文件数: {0}'}"
                           FontSize="13" Foreground="#666"/>
                <TextBlock Text="{Binding TotalSizeText, StringFormat='总大小: {0}'}"
                           FontSize="13" Foreground="#666"/>
            </StackPanel>
        </StackPanel>

        <!-- 中部预览区 -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto" Margin="0,10,0,0">
            <!-- 进度条 -->
            <ProgressBar Grid.Row="0" Value="{Binding ProgressValue}" Maximum="100"
                         Height="4" Margin="0,0,0,8"
                         IsVisible="{Binding IsProcessing}"/>

            <!-- 双栏预览 -->
            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*">
                <!-- 左侧：源文件 -->
                <Border Grid.Column="0" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer Name="LeftScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <ListBox Name="SourceFilesList"
                                 ItemsSource="{Binding PreviewItems}"
                                 Background="Transparent" Padding="8" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:FileMoveInfo">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding SourceRelativePath}"
                                                   FontFamily="Consolas, monospace" FontSize="12"
                                                   Foreground="#333" Padding="4,2"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding SourceRelativePath}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FormattedSize}"
                                                   FontSize="11" Foreground="#999" Padding="8,2,4,2"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Border>

                <!-- 中间箭头 -->
                <TextBlock Grid.Column="1" Text="→" FontSize="24" FontWeight="Bold"
                           Foreground="#007ACC" VerticalAlignment="Center" Margin="12,0"/>

                <!-- 右侧：目标预览 -->
                <Border Grid.Column="2" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4">
                    <ScrollViewer Name="RightScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <ListBox Name="MovePreviewList"
                                 ItemsSource="{Binding PreviewItems}"
                                 Background="Transparent" Padding="8" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="models:FileMoveInfo">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding TargetDisplayName}"
                                                   FontFamily="Consolas, monospace" FontSize="12"
                                                   Foreground="#333" Padding="4,2"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip.Tip="{Binding TargetDisplayName}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FormattedSize}"
                                                   FontSize="11" Foreground="#999" Padding="8,2,4,2"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 状态栏 -->
            <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="5" Padding="12,10" Margin="0,10,0,0">
                <TextBlock Text="{Binding StatusMessage}" FontWeight="Medium" FontSize="13"/>
            </Border>
        </Grid>
    </Grid>

</UserControl>
