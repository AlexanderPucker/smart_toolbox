<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartToolbox.ViewModels"
             x:Class="SmartToolbox.Views.HashCalculatorView"
             x:DataType="vm:HashCalculatorViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#005A9B"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#5A6268"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style Selector="Button.success:pointerover">
            <Setter Property="Background" Value="#218838"/>
        </Style>
        <Style Selector="TextBox.hash">
            <Setter Property="FontFamily" Value="Consolas, monospace"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding CalculateTextHashCommand}">
                    <TextBlock Text="计算文本哈希"/>
                </Button>
                <Button Classes="success" Command="{Binding CalculateFileHashCommand}">
                    <TextBlock Text="计算文件哈希..."/>
                </Button>
                <Button Classes="secondary" Command="{Binding ClearCommand}">
                    <TextBlock Text="清空"/>
                </Button>
                <CheckBox Content="大写" IsChecked="{Binding IsUpperCase}"
                          VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- 输入文本 -->
            <TextBox Text="{Binding InputText}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas, monospace"
                     FontSize="13"
                     Watermark="输入要计算哈希的文本..."
                     Height="120"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>

            <!-- 文件路径 -->
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding FilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="文件:" VerticalAlignment="Center" FontWeight="Medium"/>
                <TextBlock Text="{Binding FilePath}" VerticalAlignment="Center"
                           FontFamily="Consolas, monospace" FontSize="12" Foreground="#666"/>
            </StackPanel>
        </StackPanel>

        <!-- 哈希结果 -->
        <StackPanel Grid.Row="1" Spacing="14" Margin="0,18,0,0">
            <TextBlock Text="哈希结果" FontWeight="Bold" FontSize="16" Margin="0,0,0,4"/>

            <StackPanel Spacing="4">
                <TextBlock Text="MD5" FontWeight="Medium" FontSize="13" Foreground="#555"/>
                <TextBox Classes="hash" Text="{Binding Md5Hash}" Watermark="—"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="SHA-1" FontWeight="Medium" FontSize="13" Foreground="#555"/>
                <TextBox Classes="hash" Text="{Binding Sha1Hash}" Watermark="—"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="SHA-256" FontWeight="Medium" FontSize="13" Foreground="#555"/>
                <TextBox Classes="hash" Text="{Binding Sha256Hash}" Watermark="—"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="SHA-512" FontWeight="Medium" FontSize="13" Foreground="#555"/>
                <TextBox Classes="hash" Text="{Binding Sha512Hash}" Watermark="—"
                         TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="5" Padding="12,8" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"/>
        </Border>
    </Grid>

</UserControl>
