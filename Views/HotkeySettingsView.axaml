<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartToolbox.ViewModels"
             x:Class="SmartToolbox.Views.HotkeySettingsView"
             x:DataType="vm:HotkeySettingsViewModel">

    <Grid ColumnDefinitions="250,*">
        <Border Background="#2D2D2D" Padding="10">
            <StackPanel Spacing="10">
                <TextBlock Text="⌨️ 快捷键设置" FontSize="18" FontWeight="Bold"/>
                
                <TextBlock Text="分类筛选" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <ListBox ItemsSource="{Binding Categories}" SelectionChanged="OnCategorySelected">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="配置文件" FontWeight="SemiBold" Margin="0,10,0,0"/>
                <ListBox ItemsSource="{Binding Profiles}" Height="100">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Text="(当前)" Foreground="#4A9EFF" IsVisible="{Binding IsActive}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <Button Content="新建" Command="{Binding CreateProfileCommand}"/>
                    <Button Content="激活" Command="{Binding ActivateProfileCommand}" CommandParameter="{Binding $parent[ListBox].SelectedItem}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" Margin="10">
            <Border Background="#2D2D2D" Padding="15">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="5" Grid.Column="1">
                        <Button Content="检测冲突" Command="{Binding FindConflictsCommand}"/>
                        <Button Content="重置全部" Command="{Binding ResetAllHotkeysCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <DataGrid Grid.Row="1" ItemsSource="{Binding Hotkeys}" SelectedItem="{Binding SelectedHotkey}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Name}" Header="名称" Width="*"/>
                    <DataGridTextColumn Binding="{Binding Description}" Header="描述" Width="2*"/>
                    <DataGridTextColumn Binding="{Binding CurrentKey}" Header="快捷键" Width="100"/>
                    <DataGridTextColumn Binding="{Binding Category}" Header="分类" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Background="#2D2D2D" Padding="15" Margin="0,10,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="选中:" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedHotkey.Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="当前快捷键:" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        <TextBlock Text="{Binding SelectedHotkey.CurrentKey}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5" Grid.Column="1">
                        <Button Content="录制新快捷键" Command="{Binding StartRecordingKeyCommand}"/>
                        <Button Content="重置" Command="{Binding ResetHotkeyCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
