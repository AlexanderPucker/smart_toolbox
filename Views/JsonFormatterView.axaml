<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SmartToolbox.ViewModels"
             x:Class="SmartToolbox.Views.JsonFormatterView"
             x:DataType="vm:JsonFormatterViewModel">

    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#005A9B"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#5A6268"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style Selector="Button.success:pointerover">
            <Setter Property="Background" Value="#218838"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding FormatCommand}">
                    <TextBlock Text="格式化"/>
                </Button>
                <Button Classes="secondary" Command="{Binding SwapCommand}">
                    <TextBlock Text="交换 ⇄"/>
                </Button>
                <Button Classes="secondary" Command="{Binding ClearCommand}">
                    <TextBlock Text="清空"/>
                </Button>
                <CheckBox Content="压缩模式" IsChecked="{Binding IsCompact}"
                          VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 输入输出双栏 -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,12,0,0">
            <!-- 输入 -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*" Margin="0,0,6,0">
                <TextBlock Grid.Row="0" Text="输入" FontWeight="Medium" FontSize="14" Margin="0,0,0,6"/>
                <TextBox Grid.Row="1" Name="InputBox"
                         Text="{Binding InputJson}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas, monospace"
                         FontSize="13"
                         Watermark="粘贴 JSON 文本..."
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </Grid>

            <!-- 输出 -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="6,0,0,0">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="输出" FontWeight="Medium" FontSize="14" VerticalAlignment="Center"/>
                    <Button Classes="success" Padding="8,4" FontSize="12"
                            Command="{Binding CopyOutputCommand}">
                        <TextBlock Text="复制"/>
                    </Button>
                </StackPanel>
                <TextBox Grid.Row="1" Name="OutputBox"
                         Text="{Binding OutputJson}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas, monospace"
                         FontSize="13"
                         Background="#FAFAFA"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Margin="0,6,0,0"/>
            </Grid>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="5" Padding="12,8" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="13"/>
        </Border>
    </Grid>

</UserControl>
