<!-- 
    系统设置视图界面
    提供应用程序的各种设置选项，包括外观设置、启动行为、文件处理、高级设置和关于页面
    采用与文件移动工具类似的代码后台管理方式
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SmartToolbox.Views.SystemSettingsView">
    
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#005A9B"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#004578"/>
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="#DC3545"/>
        </Style>
        <Style Selector="Button.danger:pointerover">
            <Setter Property="Background" Value="#C82333"/>
        </Style>
        <Style Selector="Button.success">
            <Setter Property="Background" Value="#28A745"/>
        </Style>
        <Style Selector="Button.success:pointerover">
            <Setter Property="Background" Value="#218838"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="20" RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Spacing="15">

            <!-- 标题 -->
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                <TextBlock Text="⚙️" FontSize="24" VerticalAlignment="Center"/>
                <TextBlock Text="系统设置" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 外观设置 -->
            <StackPanel Spacing="10">
                <TextBlock Text="🎨 外观设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                
                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="主题:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <ComboBox Grid.Column="1" Name="ThemeComboBox" 
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="选择您喜欢的界面主题" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="语言:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <ComboBox Grid.Column="1" Name="LanguageComboBox" 
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="选择显示语言" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- 启动行为 -->
            <StackPanel Spacing="10">
                <TextBlock Text="🚀 启动行为" FontSize="16" FontWeight="Bold" Margin="0,15,0,10"/>
                
                <CheckBox Name="StartWithSystemCheckBox" 
                          Margin="0,0,0,5"
                          FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                          FontSize="14"
                          Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                    <CheckBox.Content>
                        <TextBlock Text="开机自启动" 
                                   FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </CheckBox.Content>
                </CheckBox>
                <CheckBox Name="MinimizeToTrayCheckBox" 
                          Margin="0,0,0,10"
                          FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                          FontSize="14"
                          Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                    <CheckBox.Content>
                        <TextBlock Text="启动后最小化到托盘" 
                                   FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </CheckBox.Content>
                </CheckBox>
            </StackPanel>

            <!-- 其他设置 -->
            <StackPanel Spacing="10">
                <TextBlock Text="🔧 其他设置" FontSize="16" FontWeight="Bold" Margin="0,15,0,10"/>
                
                <CheckBox Name="CheckUpdatesCheckBox" 
                          Margin="0,0,0,5"
                          FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                          FontSize="14"
                          Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                    <CheckBox.Content>
                        <TextBlock Text="自动检查更新" 
                                   FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </CheckBox.Content>
                </CheckBox>
                <CheckBox Name="AutoSaveCheckBox" 
                          Margin="0,0,0,10"
                          FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                          FontSize="14"
                          Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                    <CheckBox.Content>
                        <TextBlock Text="自动保存设置" 
                                   FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </CheckBox.Content>
                </CheckBox>
            </StackPanel>

            <!-- 文件处理设置 -->
            <StackPanel Spacing="10">
                <TextBlock Text="📁 文件处理设置" FontSize="16" FontWeight="Bold" Margin="0,15,0,10"/>
                
                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="默认保存路径:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <TextBox Grid.Column="1" Name="DefaultSavePathTextBox" 
                             Watermark="选择文件默认保存路径..."
                             IsReadOnly="True"
                             Margin="10,0,0,0"/>
                    <Button Grid.Column="2" 
                            Margin="10,0,0,0" 
                            Name="BrowseSavePathButton">
                        <TextBlock Text="浏览..."/>
                    </Button>
                </Grid>

                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="文件命名规则:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <ComboBox Grid.Column="1" Name="FileNamingRuleComboBox" 
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="设置文件命名规则" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="创建备份:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <CheckBox Grid.Column="1" Name="CreateBackupCheckBox" 
                              Content="启用文件备份" 
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="是否创建备份文件" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="备份文件数量:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <NumericUpDown Grid.Column="1" Name="BackupFileCountNumeric"
                                   Value="5" Minimum="1" Maximum="20"
                                   HorizontalAlignment="Left" Width="100"
                                   Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="设置备份文件数量上限" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- 高级设置 -->
            <StackPanel Spacing="10">
                <TextBlock Text="⚙️ 高级设置" FontSize="16" FontWeight="Bold" Margin="0,15,0,10"/>
                
                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="启用日志记录:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <CheckBox Grid.Column="1" Name="EnableLoggingCheckBox" 
                              Content="启用详细日志" 
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="记录应用程序日志" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="日志级别:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <ComboBox Grid.Column="1" Name="LogLevelComboBox" 
                              SelectedIndex="0"
                              HorizontalAlignment="Stretch"
                              Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="设置日志记录级别" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="调试模式:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <CheckBox Grid.Column="1" Name="EnableDebugModeCheckBox" 
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                              FontSize="14"
                              Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                        <CheckBox.Content>
                            <TextBlock Text="启用调试模式" 
                                       FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        </CheckBox.Content>
                    </CheckBox>
                    <TextBlock Grid.Column="2" Text="启用额外调试信息" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="120,*,Auto">
                    <TextBlock Grid.Column="0" Text="实验性功能:" VerticalAlignment="Center" FontWeight="Medium" FontSize="14"/>
                    <CheckBox Grid.Column="1" Name="EnableExperimentalFeaturesCheckBox" 
                              VerticalAlignment="Center"
                              Margin="10,0,0,0"
                              FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                              FontSize="14"
                              Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                        <CheckBox.Content>
                            <TextBlock Text="启用实验性功能" 
                                       FontFamily="Microsoft YaHei UI, Microsoft YaHei, Segoe UI, Arial"
                                       FontSize="14"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        </CheckBox.Content>
                    </CheckBox>
                    <TextBlock Grid.Column="2" Text="启用未完成的功能" 
                               VerticalAlignment="Center" FontSize="12" 
                               Foreground="#666666" Margin="10,0,0,0"/>
                </Grid>
            </StackPanel>

            <!-- 关于 -->
            <StackPanel Spacing="10">
                <TextBlock Text="ℹ️ 关于" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15,0,10"/>
                
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="📦" FontSize="36" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Name="AppNameText" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Name="AppVersionText" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Name="AppDescriptionText" FontSize="14" HorizontalAlignment="Center" TextWrapping="Wrap"/>

                    <StackPanel Spacing="5" HorizontalAlignment="Center">
                        <TextBlock Name="CopyrightText" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Name="LicenseText" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Button Name="OpenGitHubButton" 
                            HorizontalAlignment="Center" 
                            Padding="15,8" 
                            Margin="0,10,0,0">
                        <TextBlock Text="🔗 访问 GitHub"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Name="ResetSettingsButton" Classes="danger">
                    <TextBlock Text="🔄 重置为默认"/>
                </Button>
                <Button Name="SaveSettingsButton" Classes="success">
                    <TextBlock Text="💾 保存设置"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>